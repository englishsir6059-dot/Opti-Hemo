import pandas as pd
from sklearn.ensemble import RandomForestClassifier
import pickle

# 1. Load the data you collected (the 'memory')
df = pd.read_csv("data.csv", header=None)

# 2. Split into Features (Sensor numbers) and Target (Health Label)
X = df.iloc[:, :-1]
y = df.iloc[:, -1]

# 3. Build the 'Random Forest' Brain
print("🧠 Training the AI Brain... please wait...")
model = RandomForestClassifier(n_estimators=100)
model.fit(X, y)

# 4. Save the textbook (the model)
with open('model.pkl', 'wb') as f:
    pickle.dump(model, f)

print(f"🎯 SUCCESS! AI Trained. Accuracy: {model.score(X, y)*100:.2f}%")
